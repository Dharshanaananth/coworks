## Server (do NOT put these in frontend code)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

## Optional (recommended): hardcode the place_id so we don't have to look it up
GOOGLE_PLACE_ID=ChIxxxxxxxxxxxxxxxxxxxx

## Optional: if you do not set GOOGLE_PLACE_ID, we will search by this query
GOOGLE_PLACE_TEXT_QUERY=iCity Co-working Space, Coimbatore

## Server port (frontend proxy expects 5000 by default)
PORT=5000

